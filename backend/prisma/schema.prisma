generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Route {
  id           String        @id
  name         String
  year         Int
  intensity    Float
  isBaseline   Boolean       @default(false)
  shipEmission ShipEmission?

  @@index([year])
  @@index([year, isBaseline])
}

model ShipEmission {
  shipId               String
  routeId              String @unique
  year                 Int
  vesselType           String
  fuelType             String
  fuelConsumptionTons  Float
  distanceKm           Float
  totalEmissionsTonnes Float
  actualIntensity      Float
  route                Route  @relation(fields: [routeId], references: [id])

  @@id([shipId, year])
  @@index([year])
}

model ComplianceRecord {
  id                Int      @id @default(autoincrement())
  shipId            String
  year              Int
  targetIntensity   Float
  actualIntensity   Float
  energyInScopeMj   Float
  complianceBalance Float
  createdAt         DateTime @default(now())

  @@unique([shipId, year])
  @@map("ship_compliance")
}

model BankEntry {
  id                   String   @id @default(uuid())
  shipId               String
  year                 Int
  amount               Float
  usedAmount           Float    @default(0)
  sourceComplianceYear Int
  createdAt            DateTime @default(now())

  @@index([shipId, year])
}

model BankApplySnapshot {
  id        String   @id @default(uuid())
  shipId    String
  year      Int
  cbBefore  Float
  applied   Float
  cbAfter   Float
  createdAt DateTime @default(now())

  @@index([shipId, year, createdAt])
}

model Pool {
  id        String       @id
  year      Int
  shipIds   String[]
  createdAt DateTime     @default(now())
  members   PoolMember[]
}

model PoolMember {
  poolId   String
  shipId   String
  year     Int
  cbBefore Float
  cbAfter  Float
  pool     Pool   @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@id([poolId, shipId])
  @@index([shipId, year])
}
